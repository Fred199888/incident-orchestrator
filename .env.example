# 飞书
LARK_APP_ID=
LARK_APP_SECRET=
LARK_ENCRYPT_KEY=
LARK_VERIFICATION_TOKEN=
LARK_CHAT_ID=
LARK_CHAT_ID_CLS=
LARK_BOT_ID=

# 腾讯云 CLS
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
CLS_REGION=na-siliconvalley

# GitHub
GITHUB_REPO_URL=https://github.com/your-org/your-repo

# Monorepo
MONOREPO_DIR=/path/to/your/monorepo

# 数据库
DB_PATH=data/incidents.db

# 服务器
HOST=0.0.0.0
PORT=8900

# 并发
MAX_CONCURRENT_RUNS=5

# Legacy scripts
LEGACY_SCRIPTS_DIR=./legacy_scripts

# Bitable
BITABLE_APP_TOKEN=
BITABLE_TABLE_ID=

# GH_TOKEN (optional, for GitHub API)
GH_TOKEN=

# Git 用户名 → 飞书 open_id 映射（逗号分隔，格式 gitname:open_id）
GIT_USER_MAP=

# CLS Topic ID 映射（JSON 字符串）
CLS_TOPIC_ID_MAP_JSON={"service-name": "topic-uuid"}
